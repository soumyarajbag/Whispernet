# Copy this file to .env and fill in the values
# NEVER commit .env to Git — it is listed in .gitignore

PORT=3000
NODE_ENV=development

# MongoDB connection string
# Local:    mongodb://localhost:27017/whispernet
# Atlas:    mongodb+srv://<user>:<pass>@cluster.mongodb.net/whispernet
MONGODB_URI=mongodb://localhost:27017/whispernet

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h

# Admin credentials (demo only — use a hashed DB record in production)
ADMIN_USERNAME=moderator
ADMIN_PASSWORD=supersecret

# Internal webhook secret — shared between the fire function and the receiver
# Prevents random callers from hitting /webhooks/receive directly
WEBHOOK_SECRET=whispernet-internal-secret
